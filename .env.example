# Supabase — dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role key — server-only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# LLM providers — at least one required for chat; OpenAI also powers embeddings
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional: force which provider serves chat (anthropic | openai).
# Unset = auto (Anthropic preferred). Ignored if that provider's key is missing.
CHAT_PROVIDER=
